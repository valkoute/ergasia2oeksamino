#include <stdio.h>
#include <stdlib.h>
#include <string.h>
#include <time.h>

// Task 1: Δομές
#define MAX_CONTACTS 100

typedef struct
{
    int id;
    char name[20];
    char surname[50];
    char address[100];
    char phone[20];
    char email[50];
    char created_date[15];
    int deleted; // 0 = active, 1 = deleted
} Contact;

Contact contacts[MAX_CONTACTS];
int contact_count = 0;
void add_contact();
void modify_contact();
void search_contact();
void list_contacts();
void show_settings();
void delete_or_recover_contact();
void save_to_file(Contact *c);
void format_current_date(char *buffer);
int perform_search(int show_deleted);

int main()
{
    int choice = -1;

    // Task 1: Δομή του κεντρικού μενού
    while (choice != 0)
    {
        printf("   WELCOME TO PHONE BOOK APPLICATION\n");
        printf("=========================================\n");
        printf("Please select one of the following options:\n");
        printf("1- Create a new contact\n");
        printf("2- Edit an existing contact\n");
        printf("3- Search (and view) an existing contact\n");
        printf("4- View all contacts - Sort\n");
        printf("5- Settings\n");
        printf("6- Delete Contact/Recover contact\n");
        printf("0- Exit\n");
        printf("Your choice: ");

        scanf("%d", &choice);

        switch (choice)
        {
        case 1:
            add_contact();
            break;
        case 2:
            modify_contact();
            break;
        case 3:
            search_contact();
            break;
        case 4:
            list_contacts();
            break;
        case 5:
            show_settings();
            break;
        case 6:
            delete_or_recover_contact();
            break;
        case 0:
            printf("\nExiting program... Goodbye!\n");
            break;
        default:
            printf("\nInvalid choice. Please try again.\n");
        }
    }
    return 0;
}

// Αποθήκευση νέας επαφής σε αρχείο και ενημέρωση του πίνακα επαφών
void add_contact()
{
    Contact *new_c;
    if (contact_count >= MAX_CONTACTS)
    {
        printf("\nThe phone book is full!\n");
        return;
    }

    new_c = &contacts[contact_count];
    new_c->id = contact_count + 1;
    new_c->deleted = 0;
    format_current_date(new_c->created_date);

    printf("\n--- New Contact ---\n");

    // Task 1: Ελεγχος ορθότητας ονόματος (max 19 χαρακτήρες)
    while (1)
    {
        printf("Name (max 19 chars): ");
        scanf("%19s", new_c->name);
        if (strlen(new_c->name) < 20)
        {
            break;
        }
        else
        {
            printf("The name is too long!\n");
        }
    }

    printf("Surname: ");
    scanf("%49s", new_c->surname);
    printf("Address (no spaces): ");
    scanf("%99s", new_c->address);
    printf("Phone: ");
    scanf("%19s", new_c->phone);
    printf("Email: ");
    scanf("%49s", new_c->email);

    contact_count++;
    save_to_file(new_c);

    printf("\nContact saved with ID: %d!\n", new_c->id);
}

void save_to_file(Contact *c)
{
    char filename[150];
    FILE *file;

    // Task 2: Αποθηκεύεται σε φάκελο "contacts" με όνομα "surname_id.txt"
    sprintf(filename, "contacts/%s_%d.txt", c->surname, c->id);
    file = fopen(filename, "w");

    if (file == NULL)
    {
        printf("\n[ERROR] The folder 'contacts' was not found.\n");
        return;
    }

    fprintf(file, "ID: %d\nName: %s\nSurname: %s\nAddress: %s\nPhone: %s\nEmail: %s\nDate Created: %s\n",
            c->id, c->name, c->surname, c->address, c->phone, c->email, c->created_date);
    fclose(file);
}

void format_current_date(char *buffer)
{
    time_t t = time(NULL);
    struct tm tm = *localtime(&t);
    sprintf(buffer, "%02d/%02d/%d", tm.tm_mday, tm.tm_mon + 1, tm.tm_year + 1900);
}

// Συνάρτηση αναζήτησης που επιστρέφει τον αριθμό των αποτελεσμάτων και εμφανίζει τις επαφές που ταιριάζουν με τα κριτήρια.
int perform_search(int show_deleted)
{
    int search_type, i, found = 0;
    char term[50];

    printf("\n--- Search Mode ---\n");
    printf("1. By Name\n2. By Surname\n3. By Phone\n4. By Email\nChoice: ");
    scanf("%d", &search_type);

    printf("Enter search term: ");
    scanf("%49s", term);

    printf("\nResults:\n");
    for (i = 0; i < contact_count; i++)
    {
        if (contacts[i].deleted == show_deleted)
        {
            int match = 0;
            if (search_type == 1 && strcmp(contacts[i].name, term) == 0)
                match = 1;
            else if (search_type == 2 && strcmp(contacts[i].surname, term) == 0)
                match = 1;
            else if (search_type == 3 && strcmp(contacts[i].phone, term) == 0)
                match = 1;
            else if (search_type == 4 && strcmp(contacts[i].email, term) == 0)
                match = 1;

            if (match)
            {
                printf("[%d] %s %s | Tel: %s | Email: %s\n",
                       contacts[i].id, contacts[i].name, contacts[i].surname,
                       contacts[i].phone, contacts[i].email);
                found++;
            }
        }
    }

    if (found == 0)
        printf("No contacts found.\n");
    return found;
}

// Αναζήτηση και επεξεργασία επαφής
void search_contact()
{
    int id_to_view, i, found_in_search;

    found_in_search = perform_search(0); // 0 = active contacts

    if (found_in_search > 0)
    {
        printf("\nEnter the contact ID for full display (0 to cancel): ");
        scanf("%d", &id_to_view);

        if (id_to_view != 0)
        {
            for (i = 0; i < contact_count; i++)
            {
                if (contacts[i].id == id_to_view && contacts[i].deleted == 0)
                {
                    // Task 2: Εμφάνιση ημερομηνίας πριν τις πληροφορίες
                    printf("\n--- Date Created: %s ---\n", contacts[i].created_date);
                    printf("ID: %d\nName: %s\nSurname: %s\nAddress: %s\nPhone: %s\nEmail: %s\n",
                           contacts[i].id, contacts[i].name, contacts[i].surname,
                           contacts[i].address, contacts[i].phone, contacts[i].email);
                    return;
                }
            }
            printf("Invalid ID.\n");
        }
    }
}

void modify_contact()
{
    int id_to_edit, i, field;
    if (perform_search(0) == 0)
        return;

    printf("\nEnter the ID of the contact you want to edit: ");
    scanf("%d", &id_to_edit);

    for (i = 0; i < contact_count; i++)
    {
        if (contacts[i].id == id_to_edit && contacts[i].deleted == 0)
        {
            printf("\nWhat would you like to change;\n1. Name\n2. Surname\n3. Address\n4. Phone\n5. Email\nChoice: ");
            scanf("%d", &field);

            printf("Enter new value: ");
            switch (field)
            {
            case 1:
                scanf("%19s", contacts[i].name);
                break;
            case 2:
                scanf("%49s", contacts[i].surname);
                break;
            case 3:
                scanf("%99s", contacts[i].address);
                break;
            case 4:
                scanf("%19s", contacts[i].phone);
                break;
            case 5:
                scanf("%49s", contacts[i].email);
                break;
            default:
                printf("Invalid choice.\n");
                return;
            }
            save_to_file(&contacts[i]);
            printf("Contact updated!\n");
            return;
        }
    }
    printf("No contact found with that ID.\n");
}

// Διάγραφη και ανάκτηση επαφής
void delete_or_recover_contact()
{
    int choice, id, i, confirm;

    printf("\n1. Delete Contact\n2. Recover Contact\nChoice: ");
    scanf("%d", &choice);

    if (choice == 1)
    {
        if (perform_search(0) == 0)
            return;
        printf("\nEnter ID to delete: ");
        scanf("%d", &id);

        for (i = 0; i < contact_count; i++)
        {
            if (contacts[i].id == id && contacts[i].deleted == 0)
            {
                printf("Are you sure? (1 for YES, 0 for NO): ");
                scanf("%d", &confirm);
                if (confirm == 1)
                {
                    contacts[i].deleted = 1;
                    printf("Contact deleted.\n");
                }
                return;
            }
        }
    }
    else if (choice == 2)
    {
        if (perform_search(1) == 0)
            return; // Ψάχνει μόνο για διαγραμμένες επαφές
        printf("\nEnter ID to recover: ");
        scanf("%d", &id);

        for (i = 0; i < contact_count; i++)
        {
            if (contacts[i].id == id && contacts[i].deleted == 1)
            {
                contacts[i].deleted = 0;
                printf("Contact successfully recovered!\n");
                return;
            }
        }
    }
}

// Προβολή των επαφών με δυνατότητα ταξινόμησης κατά ID ή όνομα.
void list_contacts()
{
    int i, j, sort_choice;
    Contact temp;
    // Δημιουργούμε ένα προσωρινό αντίγραφο για να μην χάσουμε το original ID array
    Contact sorted[MAX_CONTACTS];
    int active_count = 0;

    for (i = 0; i < contact_count; i++)
    {
        if (contacts[i].deleted == 0)
        {
            sorted[active_count] = contacts[i];
            active_count++;
        }
    }

    if (active_count == 0)
    {
        printf("\nThere are no active contacts.\n");
        return;
    }

    printf("\nSort by:\n1. ID\n2. Name\nChoice: ");
    scanf("%d", &sort_choice);
    // Bubble Sort
    for (i = 0; i < active_count - 1; i++)
    {
        for (j = 0; j < active_count - i - 1; j++)
        {
            int swap = 0;
            if (sort_choice == 1)
            {
                if (sorted[j].id > sorted[j + 1].id)
                    swap = 1;
            }
            else if (sort_choice == 2)
            {
                if (strcmp(sorted[j].name, sorted[j + 1].name) > 0)
                    swap = 1;
            }

            if (swap)
            {
                temp = sorted[j];
                sorted[j] = sorted[j + 1];
                sorted[j + 1] = temp;
            }
        }
    }

    printf("\n--- Contact List ---\n");
    for (i = 0; i < active_count; i++)
    {
        printf("[%d] %s %s - Created: %s\n", sorted[i].id, sorted[i].name, sorted[i].surname, sorted[i].created_date);
    }
}

// Ρυθμίσεις μενού και εμφάνιση στατιστικών και διπλών εγγραφών
void show_settings()
{
    int active = 0, deleted = 0;
    int i, j;
    int found_dup = 0;

    if (contact_count == 0)
    {
        printf("\nThere are no contacts for statistics.\n");
        return;
    }

    // Στατιστικά
    for (i = 0; i < contact_count; i++)
    {
        if (contacts[i].deleted == 0)
            active++;
        else
            deleted++;
    }

    printf("\n--- Statistics ---\n");
    printf("Total Active Contacts: %d\n", active);
    printf("Deleted Contacts: %d\n", deleted);
    printf("Date of First Contact: %s\n", contacts[0].created_date);
    printf("Date of Last Contact: %s\n", contacts[contact_count - 1].created_date);

    // Αναζήτηση για διπλές εγγραφές
    printf("\n--- Duplicate Entries ---\n");
    for (i = 0; i < contact_count; i++)
    {
        if (contacts[i].deleted == 1)
            continue;
        for (j = i + 1; j < contact_count; j++)
        {
            if (contacts[j].deleted == 0 &&
                strcmp(contacts[i].name, contacts[j].name) == 0 &&
                strcmp(contacts[i].surname, contacts[j].surname) == 0 &&
                strcmp(contacts[i].email, contacts[j].email) == 0)
            {

                printf("Duplicate entry found!\n");
                printf("ID %d and ID %d -> %s %s (%s)\n",
                       contacts[i].id, contacts[j].id,
                       contacts[i].name, contacts[i].surname, contacts[i].email);
                found_dup = 1;
            }
        }
    }

    if (found_dup == 0)
    {
        printf("No duplicate entries found.\n");
    }
}
